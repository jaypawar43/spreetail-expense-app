# Normalize line endings to LF in the repo; Git converts to CRLF on Windows checkout
* text=auto eol=lf

# Force binary treatment for these types (never convert)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.db binary
*.sqlite3 binary

# Python files always LF
*.py text eol=lf

# JS/TS/JSON/CSS always LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf

# Config files always LF
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env.example text eol=lf
Procfile text eol=lf

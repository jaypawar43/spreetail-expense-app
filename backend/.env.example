# ─────────────────────────────────────────────────────────────────
# Expense Splitter — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Django Core ──────────────────────────────────────────────────
# Generate a secure key with:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-me

# Set to False in production
DEBUG=False

# ── Allowed Hosts ─────────────────────────────────────────────────
# Comma-separated. Add your Render service hostname here.
# Example:  expense-splitter.onrender.com,localhost,127.0.0.1
ALLOWED_HOSTS=your-app.onrender.com,localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────
# Leave blank to use SQLite (local dev only).
# On Render: copy the "Internal Database URL" from your PostgreSQL service.
DATABASE_URL=postgresql://user:password@host:5432/expense_splitter

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Add your Vercel deployment URL here.
# Example:  https://expense-splitter.vercel.app,http://localhost:5173
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ── CSRF Trusted Origins (required for Render HTTPS) ──────────────
# Same as CORS_ALLOWED_ORIGINS but used by Django's CSRF middleware.
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://your-app.vercel.app

# ── OpenAI (optional) ─────────────────────────────────────────────
# Without this key, the app uses rule-based anomaly detection (fully functional).
# With this key, AI-powered duplicate detection and expense categorization activate.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ── Exchange Rate ─────────────────────────────────────────────────
# Default USD → INR rate used for settlement calculations.
# Users can override this from the UI at runtime.
USD_TO_INR_RATE=83.0
